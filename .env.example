# Supabase — guestbook backend.
# Create a project at https://supabase.com and copy these from
# Project Settings → API. The anon key is safe to expose in the client.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Service-role key — used ONLY by `npm run backfill:guestbook` to translate
# existing guestbook rows (RLS blocks anon writes). No VITE_ prefix: it must
# stay server-side and never reach the client bundle. Leave blank otherwise.
SUPABASE_SERVICE_ROLE_KEY=

# Translation runs in the `translate` Supabase Edge Function (it calls Claude).
# The Anthropic API key is NOT set here — it lives only as a Supabase secret:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# (optionally ANTHROPIC_MODEL to override the default model). See the README.

# Google Analytics 4 measurement ID (https://analytics.google.com/).
VITE_GA_MEASUREMENT_ID=G-DZG1NY9ZRV

# Blizzard API — used at BUILD TIME ONLY to refresh the WoW character render
# (npm run build / npm run fetch:wow). Create a client at
# https://develop.battle.net/. No VITE_ prefix: these stay server-side and
# never reach the client bundle. Leave blank to keep the current image.
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=
